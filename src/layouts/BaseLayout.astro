---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  jsonLd?: Record<string, unknown>;
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="bg-bg">
  <head>
    <SEOHead {...props} />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Amazon Baby-Wunschliste Promotion Banner -->
    <div id="promo-banner" class="bg-gradient-to-r from-amber-50 to-yellow-50 border-b border-amber-200/50">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-center gap-2 sm:gap-3 text-xs sm:text-sm">
        <span class="hidden sm:inline">&#127873;</span>
        <span class="text-amber-800 font-heading font-semibold">
          <span class="hidden sm:inline">Amazon Baby-Wunschliste:</span>
          <span class="sm:hidden">Baby-Wunschliste:</span>
          <span class="font-normal"> 15% Rabatt auf Babyprodukte</span>
        </span>
        <a
          href="https://www.amazon.de/baby-reg?tag=jalapeno123-21"
          target="_blank"
          rel="noopener sponsored"
          class="inline-flex items-center gap-1 px-3 py-1 bg-amber-400 hover:bg-amber-500 text-amber-900 font-heading font-bold rounded-full text-xs transition-colors whitespace-nowrap"
        >
          Kostenlos erstellen
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <button id="promo-close" class="p-1 text-amber-700/60 hover:text-amber-900 transition-colors rounded-md hover:bg-amber-100/50 flex-shrink-0" aria-label="Banner schließen">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
    <script>
      const closeBtn = document.getElementById('promo-close');
      const banner = document.getElementById('promo-banner');
      if (sessionStorage.getItem('promo-closed')) {
        banner?.classList.add('hidden');
      }
      closeBtn?.addEventListener('click', () => {
        banner?.classList.add('hidden');
        sessionStorage.setItem('promo-closed', 'true');
      });
    </script>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
