---
interface Props {
  label: string;
  id: string;
}

const { label, id } = Astro.props;
---

<label class="flex items-center gap-3 p-3 rounded-xl hover:bg-primary/5 transition-colors cursor-pointer group">
  <input
    type="checkbox"
    id={id}
    class="w-5 h-5 rounded border-primary/30 text-primary accent-[var(--color-primary)]"
  />
  <span class="text-sm group-has-[:checked]:line-through group-has-[:checked]:text-text-light transition-colors">
    {label}
  </span>
</label>
