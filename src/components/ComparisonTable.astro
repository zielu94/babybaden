---
interface Product {
  name: string;
  feature: string;
  rating: string;
  affiliateLink?: string;
  recommended?: boolean;
}

interface Props {
  products: Product[];
}

const AMAZON_TAG = 'jalapeno123-21';

const { products } = Astro.props;

function getAmazonLink(product: Product) {
  return product.affiliateLink || `https://www.amazon.de/s?k=${encodeURIComponent(product.name)}&tag=${AMAZON_TAG}`;
}
---

<!-- Desktop Table -->
<div class="hidden md:block my-8 overflow-x-auto">
  <table class="w-full bg-white rounded-2xl overflow-hidden shadow-sm border border-primary/10">
    <thead>
      <tr class="bg-primary/5">
        <th class="px-4 py-3 text-left font-heading font-bold text-sm">Produkt</th>
        <th class="px-4 py-3 text-left font-heading font-bold text-sm">Highlight</th>
        <th class="px-4 py-3 text-center font-heading font-bold text-sm">Bewertung</th>
        <th class="px-4 py-3 text-center font-heading font-bold text-sm"></th>
      </tr>
    </thead>
    <tbody>
      {products.map((p) => (
        <tr class:list={['border-t border-primary/10', p.recommended && 'bg-accent/5']}>
          <td class="px-4 py-4">
            <div class="flex items-center gap-2">
              {p.recommended && (
                <span class="text-xs font-heading font-bold bg-accent text-text px-2 py-0.5 rounded-full">Tipp</span>
              )}
              <span class="font-semibold text-sm">{p.name}</span>
            </div>
          </td>
          <td class="px-4 py-4 text-sm text-text-light">{p.feature}</td>
          <td class="px-4 py-4 text-sm text-center">&#11088; {p.rating}</td>
          <td class="px-4 py-4 text-center">
            <a
              href={getAmazonLink(p)}
              target="_blank"
              rel="nofollow noopener sponsored"
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-[#FF9900] hover:bg-[#E8860D] text-white text-xs font-heading font-bold rounded-full transition-colors shadow-sm"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M.045 18.02c.07-.116.36-.31.77-.583 3.53-2.26 6.862-3.39 9.97-3.39 3.39 0 6.69 1.11 9.91 3.34.21.14.4.28.54.42.18.18.2.35.07.52-.1.13-.27.2-.48.2-.12 0-.28-.04-.47-.12a17.8 17.8 0 00-9.53-2.73c-3.36 0-6.53.91-9.52 2.73-.17.1-.33.15-.47.15-.27 0-.43-.13-.49-.38a.46.46 0 01-.03-.16l.24-.02z"/>
                <path d="M6.27 15.87c.04-.12.18-.26.42-.42 2.81-1.72 5.76-2.58 8.83-2.58 2.58 0 5.07.63 7.47 1.88.3.16.48.34.54.55.04.12.02.24-.07.36-.12.16-.3.22-.52.18-.1-.02-.24-.08-.42-.18a18.6 18.6 0 00-6.95-1.76c-2.86 0-5.6.78-8.24 2.33-.16.1-.3.15-.4.15-.2 0-.33-.1-.38-.28-.02-.08 0-.16.05-.23h-.33z"/>
              </svg>
              Ansehen
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<!-- Mobile Cards -->
<div class="md:hidden space-y-4 my-8">
  {products.map(p => (
    <div class:list={['bg-white rounded-2xl p-4 shadow-sm border', p.recommended ? 'border-accent' : 'border-primary/10']}>
      {p.recommended && (
        <span class="inline-block text-xs font-heading font-bold bg-accent text-text px-2 py-0.5 rounded-full mb-2">Unser Tipp</span>
      )}
      <h4 class="font-heading font-bold text-base">{p.name}</h4>
      <p class="text-sm text-text-light mt-1">{p.feature}</p>
      <div class="flex items-center justify-between mt-3">
        <div class="text-sm">
          <span>&#11088; {p.rating}</span>
        </div>
        <a
          href={getAmazonLink(p)}
          target="_blank"
          rel="nofollow noopener sponsored"
          class="inline-flex items-center gap-1.5 px-4 py-2 bg-[#FF9900] hover:bg-[#E8860D] text-white text-xs font-heading font-bold rounded-full transition-colors shadow-sm"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.045 18.02c.07-.116.36-.31.77-.583 3.53-2.26 6.862-3.39 9.97-3.39 3.39 0 6.69 1.11 9.91 3.34.21.14.4.28.54.42.18.18.2.35.07.52-.1.13-.27.2-.48.2-.12 0-.28-.04-.47-.12a17.8 17.8 0 00-9.53-2.73c-3.36 0-6.53.91-9.52 2.73-.17.1-.33.15-.47.15-.27 0-.43-.13-.49-.38a.46.46 0 01-.03-.16l.24-.02z"/>
            <path d="M6.27 15.87c.04-.12.18-.26.42-.42 2.81-1.72 5.76-2.58 8.83-2.58 2.58 0 5.07.63 7.47 1.88.3.16.48.34.54.55.04.12.02.24-.07.36-.12.16-.3.22-.52.18-.1-.02-.24-.08-.42-.18a18.6 18.6 0 00-6.95-1.76c-2.86 0-5.6.78-8.24 2.33-.16.1-.3.15-.4.15-.2 0-.33-.1-.38-.28-.02-.08 0-.16.05-.23h-.33z"/>
          </svg>
          Ansehen
        </a>
      </div>
    </div>
  ))}
</div>
