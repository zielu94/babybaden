---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="my-6 bg-amber-50 border-l-4 border-amber-400 rounded-r-xl px-5 py-4">
  <div class="flex items-start gap-3">
    <span class="text-xl flex-shrink-0" aria-hidden="true">&#9888;&#65039;</span>
    <div>
      <span class="font-heading font-bold text-sm text-amber-700">Wichtig</span>
      <p class="mt-1 text-sm text-text-light leading-relaxed">{text}</p>
    </div>
  </div>
</div>
