---
interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  image = '/images/hero/baby-baden-hero.jpg',
  imageAlt = 'Baby wird liebevoll gebadet',
  type = 'website',
  publishedDate,
  modifiedDate,
  canonicalUrl,
  jsonLd,
} = Astro.props;

const siteTitle = 'babybaden.de';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

// Canonical URL immer mit Trailing Slash normalisieren
const rawCanonical = canonicalUrl || Astro.url.href;
const canonicalUrlObj = new URL(rawCanonical);
if (!canonicalUrlObj.pathname.endsWith('/')) {
  canonicalUrlObj.pathname += '/';
}
const canonical = canonicalUrlObj.href;

const ogImage = new URL(image, Astro.site).href;

const publishedMeta = publishedDate ? `<meta property="article:published_time" content="${publishedDate}" />` : '';
const modifiedMeta = modifiedDate ? `<meta property="article:modified_time" content="${modifiedDate}" />` : '';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="de" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />
<meta name="robots" content="index, follow" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate" type="application/rss+xml" title="babybaden.de RSS Feed" href="/rss.xml" />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Nunito:wght@600;700;800&display=swap" rel="stylesheet" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content="de_DE" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={imageAlt} />

<!-- Pinterest -->
<meta name="pinterest-rich-pin" content="true" />

<Fragment set:html={publishedMeta} />
<Fragment set:html={modifiedMeta} />

<!-- Google Analytics (GA4) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-QLGRN3TJ3N"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-QLGRN3TJ3N');
</script>

<!-- JSON-LD -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
