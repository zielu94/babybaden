---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <>
    {/* Desktop: Sticky Sidebar TOC */}
    <nav class="hidden lg:block bg-white/80 backdrop-blur-sm border border-primary/10 rounded-2xl p-5 sticky top-24 h-fit shadow-sm" id="desktop-toc">
      <h3 class="font-heading font-bold text-sm uppercase tracking-wider text-primary-dark mb-4 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        Inhaltsverzeichnis
      </h3>
      <ul class="space-y-1" id="toc-list">
        {filteredHeadings.map(h => (
          <li class:list={[h.depth === 3 && 'ml-4']}>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class:list={[
                "block py-1.5 px-3 text-sm rounded-lg transition-all duration-200",
                "text-text-light hover:text-primary-dark hover:bg-primary/5",
                h.depth === 3 && "text-xs"
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* Mobile: Floating TOC Button + Slide-up Panel */}
    <button
      id="mobile-toc-btn"
      class="lg:hidden fixed bottom-6 right-6 z-50 w-12 h-12 bg-primary-dark text-white rounded-full shadow-lg flex items-center justify-center hover:bg-primary active:scale-95 transition-all"
      aria-label="Inhaltsverzeichnis öffnen"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
      </svg>
    </button>

    {/* Mobile TOC Overlay */}
    <div id="mobile-toc-overlay" class="lg:hidden fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-black/30 backdrop-blur-sm" id="mobile-toc-backdrop"></div>
      <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl shadow-2xl max-h-[70vh] overflow-y-auto transform translate-y-full transition-transform duration-300" id="mobile-toc-panel">
        <div class="sticky top-0 bg-white rounded-t-3xl px-5 pt-4 pb-3 border-b border-primary/10">
          <div class="w-10 h-1 bg-primary/20 rounded-full mx-auto mb-3"></div>
          <div class="flex items-center justify-between">
            <h3 class="font-heading font-bold text-base text-primary-dark flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
              </svg>
              Inhaltsverzeichnis
            </h3>
            <button id="mobile-toc-close" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-primary/5 text-text-light">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
        <nav class="px-5 py-4">
          <ul class="space-y-1">
            {filteredHeadings.map(h => (
              <li class:list={[h.depth === 3 && 'ml-4']}>
                <a
                  href={`#${h.slug}`}
                  data-toc-link-mobile={h.slug}
                  class:list={[
                    "block py-2.5 px-3 text-sm rounded-lg transition-all duration-200 mobile-toc-link",
                    "text-text hover:text-primary-dark hover:bg-primary/5",
                    h.depth === 3 && "text-xs text-text-light"
                  ]}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  </>
)}

<script>
  // ScrollSpy: Highlight active section in TOC
  document.addEventListener('DOMContentLoaded', () => {
    const tocLinks = document.querySelectorAll('[data-toc-link]');
    const mobileTocLinks = document.querySelectorAll('[data-toc-link-mobile]');
    if (tocLinks.length === 0) return;

    const headingIds = Array.from(tocLinks).map(link =>
      (link as HTMLElement).dataset.tocLink!
    );

    const headingElements = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    // Intersection Observer for scroll spy
    let activeId = '';
    const observer = new IntersectionObserver(
      (entries) => {
        // Find the topmost visible heading
        const visibleEntries = entries.filter(e => e.isIntersecting);
        if (visibleEntries.length > 0) {
          activeId = visibleEntries[0].target.id;
        } else {
          // If no heading is visible, find the last one above the viewport
          const scrollY = window.scrollY + 120;
          for (let i = headingElements.length - 1; i >= 0; i--) {
            if (headingElements[i].offsetTop <= scrollY) {
              activeId = headingElements[i].id;
              break;
            }
          }
        }
        updateActiveLink(activeId);
      },
      {
        rootMargin: '-80px 0px -70% 0px',
        threshold: 0,
      }
    );

    headingElements.forEach(el => observer.observe(el));

    function updateActiveLink(id: string) {
      tocLinks.forEach(link => {
        const linkEl = link as HTMLElement;
        if (linkEl.dataset.tocLink === id) {
          linkEl.classList.add('bg-primary/10', 'text-primary-dark', 'font-medium');
          linkEl.classList.remove('text-text-light');
        } else {
          linkEl.classList.remove('bg-primary/10', 'text-primary-dark', 'font-medium');
          linkEl.classList.add('text-text-light');
        }
      });
      mobileTocLinks.forEach(link => {
        const linkEl = link as HTMLElement;
        if (linkEl.dataset.tocLinkMobile === id) {
          linkEl.classList.add('bg-primary/10', 'text-primary-dark', 'font-medium');
        } else {
          linkEl.classList.remove('bg-primary/10', 'text-primary-dark', 'font-medium');
        }
      });
    }

    // Mobile TOC toggle
    const btn = document.getElementById('mobile-toc-btn');
    const overlay = document.getElementById('mobile-toc-overlay');
    const panel = document.getElementById('mobile-toc-panel');
    const backdrop = document.getElementById('mobile-toc-backdrop');
    const closeBtn = document.getElementById('mobile-toc-close');

    function openMobileToc() {
      overlay?.classList.remove('hidden');
      requestAnimationFrame(() => {
        panel?.classList.remove('translate-y-full');
        panel?.classList.add('translate-y-0');
      });
    }

    function closeMobileToc() {
      panel?.classList.add('translate-y-full');
      panel?.classList.remove('translate-y-0');
      setTimeout(() => overlay?.classList.add('hidden'), 300);
    }

    btn?.addEventListener('click', openMobileToc);
    backdrop?.addEventListener('click', closeMobileToc);
    closeBtn?.addEventListener('click', closeMobileToc);

    // Close mobile TOC when clicking a link
    document.querySelectorAll('.mobile-toc-link').forEach(link => {
      link.addEventListener('click', () => {
        closeMobileToc();
      });
    });
  });
</script>
