---
interface Props {
  name: string;
  features: string[];
  rating?: string;
  price?: string;
  affiliateLink?: string;
  badge?: string;
  image?: string;
  imagePosition?: string;
  imageFit?: 'cover' | 'contain';
}

const AMAZON_TAG = 'jalapeno123-21';

const {
  name,
  features,
  rating = '4,5/5',
  price,
  affiliateLink,
  badge,
  image,
  imagePosition,
  imageFit = 'cover',
} = Astro.props;

const amazonLink = affiliateLink || `https://www.amazon.de/s?k=${encodeURIComponent(name)}&tag=${AMAZON_TAG}`;
---

<div class="relative bg-white rounded-2xl border border-primary/15 p-5 md:p-6 my-6 shadow-sm">
  {badge && (
    <span class="absolute -top-3 left-4 inline-block px-3 py-1 text-xs font-heading font-bold bg-accent text-text rounded-full shadow-sm">
      {badge}
    </span>
  )}

  <div class="flex flex-col sm:flex-row gap-5">
    <!-- Product Image -->
    <div class="flex-shrink-0 w-full sm:w-36 h-36 bg-primary/5 rounded-xl flex items-center justify-center overflow-hidden">
      {image ? (
        <img src={image} alt={name} class={`w-full h-full ${imageFit === 'contain' ? 'object-contain' : 'object-cover'}`} style={imagePosition ? `object-position: ${imagePosition}` : undefined} loading="lazy" />
      ) : (
        <svg class="w-12 h-12 text-primary/30" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
        </svg>
      )}
    </div>

    <div class="flex-1 min-w-0">
      <h3 class="font-heading font-bold text-lg leading-snug">{name}</h3>

      <ul class="mt-3 space-y-1.5">
        {features.map(f => (
          <li class="flex items-start gap-2 text-sm text-text-light">
            <svg class="w-4 h-4 mt-0.5 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span set:html={f} />
          </li>
        ))}
      </ul>

      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span class="text-sm text-text-light">&#11088; {rating} (Amazon)</span>
        {price && (
          <span class="text-sm font-heading font-semibold text-primary-dark">{price}</span>
        )}
      </div>

      <a
        href={amazonLink}
        target="_blank"
        rel="nofollow noopener sponsored"
        class="mt-4 inline-flex items-center justify-center gap-2 px-7 py-3 bg-[#FF9900] hover:bg-[#E8860D] text-white font-heading font-bold text-sm rounded-full transition-colors shadow-md hover:shadow-lg"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M.045 18.02c.07-.116.36-.31.77-.583 3.53-2.26 6.862-3.39 9.97-3.39 3.39 0 6.69 1.11 9.91 3.34.21.14.4.28.54.42.18.18.2.35.07.52-.1.13-.27.2-.48.2-.12 0-.28-.04-.47-.12a17.8 17.8 0 00-9.53-2.73c-3.36 0-6.53.91-9.52 2.73-.17.1-.33.15-.47.15-.27 0-.43-.13-.49-.38a.46.46 0 01-.03-.16l.24-.02z"/>
          <path d="M6.27 15.87c.04-.12.18-.26.42-.42 2.81-1.72 5.76-2.58 8.83-2.58 2.58 0 5.07.63 7.47 1.88.3.16.48.34.54.55.04.12.02.24-.07.36-.12.16-.3.22-.52.18-.1-.02-.24-.08-.42-.18a18.6 18.6 0 00-6.95-1.76c-2.86 0-5.6.78-8.24 2.33-.16.1-.3.15-.4.15-.2 0-.33-.1-.38-.28-.02-.08 0-.16.05-.23h-.33z"/>
          <path d="M14.27 2.68c-1.7 0-3.16.66-4.4 1.97-1.6 1.74-2.4 3.96-2.4 6.65 0 2.34.64 4.3 1.93 5.87 1.15 1.4 2.53 2.1 4.13 2.1 1.2 0 2.28-.37 3.24-1.1.82-.63 1.4-1.42 1.72-2.36.18-.52.27-1.13.27-1.82V12.7c0-1.1-.27-1.88-.82-2.35-.46-.4-1.2-.6-2.2-.6h-.18c-.7 0-1.24.14-1.62.43-.4.3-.6.77-.6 1.4 0 .6.2 1.05.6 1.35.3.24.72.36 1.24.36h.3c.53 0 .95-.14 1.26-.42.14-.13.23-.27.3-.42v.76c0 .9-.14 1.6-.42 2.1-.42.72-1.13 1.08-2.12 1.08-.98 0-1.8-.5-2.46-1.5-.74-1.14-1.12-2.65-1.12-4.54 0-2.27.5-4.05 1.5-5.33.87-1.12 1.93-1.68 3.18-1.68.86 0 1.58.22 2.16.66.47.36.82.84 1.05 1.44l.06.03c.1 0 .2-.1.27-.27.06-.15.07-.3.02-.44-.33-1.02-.9-1.82-1.73-2.4-.86-.63-1.86-.94-3-1z"/>
        </svg>
        Auf Amazon ansehen
      </a>
    </div>
  </div>
</div>
