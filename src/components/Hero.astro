                </div>
                <svg class="w-4 h-4 text-text-light/30 group-hover:text-primary-dark transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
