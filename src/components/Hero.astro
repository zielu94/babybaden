  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 w-full">
    <svg viewBox="0 0 1200 60" fill="none" class="w-full" preserveAspectRatio="none">
      <path d="M0 30c200-20 400 15 600-5s300 20 400 10 150-15 200-10v35H0z" fill="var(--color-bg)"/>
    </svg>
