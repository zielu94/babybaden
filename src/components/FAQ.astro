---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'Häufige Fragen' } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="my-10">
  <h2 class="font-heading font-bold text-2xl mb-6">{title}</h2>
  <div class="space-y-3">
    {items.map((item, i) => (
      <details class="group bg-white rounded-xl border border-primary/10 overflow-hidden">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-heading font-semibold text-base hover:bg-primary/5 transition-colors">
          <span>{item.question}</span>
          <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-45 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-light leading-relaxed">
          <p set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
