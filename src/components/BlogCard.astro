---
interface Props {
  title: string;
  description: string;
  slug: string;
  image?: string;
  imageAlt?: string;
  category?: string;
  pubDate: Date;
  readingTime?: number;
}

const {
  title,
  description,
  slug,
  image,
  imageAlt = '',
  category = 'Ratgeber',
  pubDate,
  readingTime = 5,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
  <a href={`/ratgeber/${slug}/`} class="block">
    <div class="aspect-[16/10] bg-primary/10 overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={imageAlt}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-primary/30">
          <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
          </svg>
        </div>
      )}
    </div>
    <div class="p-5">
      <span class="inline-block px-3 py-1 text-xs font-heading font-semibold bg-primary/10 text-primary-dark rounded-full mb-3">
        {category}
      </span>
      <h3 class="font-heading font-bold text-lg leading-snug group-hover:text-primary-dark transition-colors line-clamp-2">
        {title}
      </h3>
      <p class="mt-2 text-sm text-text-light leading-relaxed line-clamp-2">
        {description}
      </p>
      <div class="mt-4 flex items-center gap-3 text-xs text-text-light">
        <span>{readingTime} Min. Lesezeit</span>
        <span>&middot;</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>
