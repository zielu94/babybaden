    </header>

    <!-- Trust Badges -->
    <div class="mb-10 bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
      <h2 class="font-heading font-bold text-lg mb-4">&#128203; 3 Kategorien – sanfte Pflege fürs Baby-Bad</h2>
      <div class="grid grid-cols-3 gap-4">
        <a href="#badezusaetze" class="flex flex-col items-center gap-2 p-3 rounded-xl hover:bg-primary/5 transition-colors text-center">
          <span class="text-3xl">&#128704;</span>
          <span class="text-sm font-heading font-semibold">Badezusätze</span>
          <span class="text-xs text-text-light">Waschgels & Schaumbäder</span>
