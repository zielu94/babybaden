          <span class="text-xs text-text-light">Badeöl & Schaumbad</span>
        </a>
        <a href="#pflegeoele" class="flex flex-col items-center gap-2 p-3 rounded-xl hover:bg-primary/5 transition-colors text-center">
          <span class="text-3xl">&#129524;</span>
          <span class="text-sm font-heading font-semibold">Pflegeöle</span>
          <span class="text-xs text-text-light">Massage & Hautpflege</span>
        </a>
      </div>
    </div>

    <!-- Bestseller Top 3 Hero -->
    <div class="mb-10 bg-gradient-to-br from-accent/10 to-primary/5 rounded-2xl p-6 md:p-8 border-2 border-accent/30 shadow-sm">
      <p class="text-sm font-heading font-bold text-accent-dark mb-2">&#127942; Unsere Top 3 Empfehlungen 2026</p>
      <div class="grid sm:grid-cols-3 gap-4">
