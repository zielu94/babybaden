---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AmazonProductBox from '../../components/AmazonProductBox.astro';
import MamaTipp from '../../components/MamaTipp.astro';
import WichtigHinweis from '../../components/WichtigHinweis.astro';
import FAQ from '../../components/FAQ.astro';

const AMAZON_TAG = 'jalapeno123-21';

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Die 13 besten Baby-Pflegeprodukte 2026',
  numberOfItems: 13,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'WELEDA Calendula Schlaf Gut Bad', url: `https://www.amazon.de/dp/B0FN4BD48B?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 2, name: 'Penaten Wasch- & Duschcreme', url: `https://www.amazon.de/dp/B07V15BFK8?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 3, name: 'Bübchen Baby-Bad mit Kamille', url: `https://www.amazon.de/dp/B09W5XBHZT?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 4, name: 'Penaten Ultra Sensitiv Bad & Shampoo', url: `https://www.amazon.de/dp/B01N3B1IET?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 5, name: 'NIVEA Baby Good Night Bad & Shampoo', url: `https://www.amazon.de/dp/B0CX1Q46S5?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 6, name: 'MABYEN Baby Bademilch', url: `https://www.amazon.de/dp/B0F8W3QDZV?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 7, name: 'boep Babybadeöl Naturkosmetik', url: `https://www.amazon.de/dp/B0DXQ13CS5?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 8, name: 'boep Schaumbad Naturkosmetik', url: `https://www.amazon.de/dp/B078S6273X?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 9, name: 'Weleda Calendula Pflegeöl Parfümfrei', url: `https://www.amazon.de/dp/B00B25PIXG?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 10, name: 'BAYBIES Baby Pflege Öl', url: `https://www.amazon.de/dp/B09TFS98RZ?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 11, name: 'JOHNSON\'S Baby Oil', url: `https://www.amazon.de/dp/B00BN7ZZ8Q?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 12, name: 'ELIAH SAHIL Bio Baby Öl', url: `https://www.amazon.de/dp/B07S965NL5?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 13, name: 'NIVEA Baby Pflege & Massage Öl', url: `https://www.amazon.de/dp/B0CX1QWZ8Q?tag=${AMAZON_TAG}` },
  ],
};

const faqItems = [
  {
    question: 'Braucht mein Baby überhaupt Badezusätze?',
    answer: 'In den ersten 4-6 Wochen reicht <strong>klares Wasser</strong> völlig aus. Danach kannst du milde, rückfettende Badezusätze verwenden &ndash; besonders wenn die Haut trocken wird. Achte auf pH-neutrale Produkte ohne Parfüm, Farbstoffe und Alkohol.'
  },
  {
    question: 'Was ist der Unterschied zwischen Badeöl und Pflegeöl?',
    answer: '<strong>Badeöl</strong> kommt direkt ins Badewasser und bildet einen schützenden Film auf der Haut. <strong>Pflegeöl</strong> wird nach dem Baden auf die noch leicht feuchte Haut aufgetragen und zieht ein. Beides pflegt &ndash; Pflegeöl ist intensiver und ideal für die Babymassage.'
  },
  {
    question: 'Wie oft sollte ich mein Baby mit Seife/Waschgel waschen?',
    answer: 'Maximal <strong>1-2 Mal pro Woche</strong> mit mildem Waschgel baden. Zu häufiges Waschen mit Seife trocknet die empfindliche Babyhaut aus und zerstört den natürlichen Säureschutzmantel. An den anderen Tagen reicht ein kurzes Bad in klarem Wasser oder ein Waschlappen.'
  },
  {
    question: 'Naturkosmetik oder konventionelle Produkte &ndash; was ist besser für Babys?',
    answer: 'Beide können gut sein! <strong>Naturkosmetik</strong> (z.B. Weleda, boep) verzichtet auf synthetische Inhaltsstoffe und ist oft besser verträglich. <strong>Konventionelle Marken</strong> (Penaten, NIVEA) sind dermatologisch getestet, günstiger und in jeder Drogerie erhältlich. Wichtiger als das Label ist, dass das Produkt parfümfrei und pH-neutral ist.'
  },
  {
    question: 'Wann sollte ich Pflegeöl nach dem Baden auftragen?',
    answer: 'Am besten direkt nach dem Baden auf die <strong>noch leicht feuchte Haut</strong>. So schließt das Öl die Feuchtigkeit ein und zieht besonders gut ein. 2-3 Tropfen reichen für den ganzen Babykörper. Spare Gesicht und Windelbereich aus &ndash; dort besser eine leichte Creme verwenden.'
  },
  {
    question: 'Welche Inhaltsstoffe sollte ich bei Babypflegeprodukten meiden?',
    answer: 'Meide Produkte mit <strong>Parfüm/Duftstoffen, Alkohol (Ethanol), Parabenen, Mineralöl (Paraffin), PEG-Emulgatoren</strong> und synthetischen Farbstoffen. Diese können die empfindliche Babyhaut reizen. Achte auf Siegel wie NATRUE, BDIH oder Dermatest &bdquo;sehr gut&ldquo;.'
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Baby Pflegeprodukte: Die 13 besten Badezusätze & Öle im Test 2026"
  description="Baby Pflegeprodukte Test 2026: Weleda, Penaten, boep & Bübchen im Vergleich. Naturkosmetik, SLS-frei, pH-neutral. Badezusätze ab 3€ – ehrlich empfohlen."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <Breadcrumb items={[
      { label: 'Produkte', href: '/produkte/' },
      { label: 'Pflegeprodukte' }
    ]} />

    <!-- Intro -->
    <header class="mb-10">
