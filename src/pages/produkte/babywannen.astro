---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import AmazonProductBox from '../../components/AmazonProductBox.astro';
import FAQ from '../../components/FAQ.astro';
import MamaTipp from '../../components/MamaTipp.astro';
import WichtigHinweis from '../../components/WichtigHinweis.astro';

const AMAZON_TAG = 'jalapeno123-21';

const products = [
  {
    name: 'FawnsLife Babywanne faltbar mit Knieschutz',
    feature: 'Premium PP+TPE, faltbar, Knieschutz für Eltern',
    rating: '4,6',
    affiliateLink: `https://www.amazon.de/dp/B0CGXLRJQ3?tag=${AMAZON_TAG}`,
    recommended: true,
  },
  {
    name: 'Faltbare Babybadewanne mit Stützkissen & Temperatursensor',
    feature: 'Faltbar, Stützkissen, Temperatursensor, leicht',
    rating: '4,5',
    affiliateLink: `https://www.amazon.de/dp/B0BB1Y5K36?tag=${AMAZON_TAG}`,
  },
  {
    name: 'Faltbare Babybadewanne XXL mit Thermometer (3-Stufen)',
    feature: 'XXL-Größe, Thermometer, 3 Altersstufen',
    rating: '4,4',
    affiliateLink: `https://www.amazon.de/dp/B0B9HQDZ6H?tag=${AMAZON_TAG}`,
  },
  {
    name: 'Babykajo Babywanne mit Gestell (4er-Set, TÜV zertifiziert)',
    feature: 'Mit Metallgestell, TÜV-zertifiziert, Badewannensitz inkl.',
    rating: '4,4',
    affiliateLink: `https://www.amazon.de/dp/B07X2TFZCL?tag=${AMAZON_TAG}`,
  },
  {
    name: 'moovkee Babybadewanne mit Gestell 80cm',
    feature: 'LCD-Thermometer, Badekissen, Gestell, bis 30kg',
    rating: '4,3',
    affiliateLink: `https://www.amazon.de/dp/B0CDLWBNW1?tag=${AMAZON_TAG}`,
  },
];

const faqItems = [
  {
    question: 'Ab wann brauche ich eine Babywanne?',
    answer: 'Sobald der <strong>Nabelschnurrest abgefallen</strong> und der Nabel verheilt ist (ca. 5-10 Tage nach der Geburt) kannst du dein Baby in einer Babywanne baden. Vorher reicht ein feuchter Waschlappen. Das erste Bad ist ein besonderer Moment &ndash; lass dir von deiner Hebamme Tipps geben!'
  },
  {
    question: 'Faltbare Babywanne oder Babywanne mit Gestell &ndash; was ist besser?',
    answer: '<strong>Faltbare Wannen</strong> sind ideal bei wenig Platz, zum Reisen und als günstige Lösung . <strong>Wannen mit Gestell</strong> sind rückenschonender, da du dein Baby auf Bauchhöhe badest &ndash; Gold wert nach einem Kaiserschnitt! Beides funktioniert gut, es kommt auf deine Wohnsituation und dein Budget an.'
  },
  {
    question: 'Wie lange kann ich eine Babywanne nutzen?',
    answer: 'Die meisten Babywannen sind bis ca. <strong>12-24 Monate</strong> nutzbar. Größere Modelle (wie die XXL-Variante) schaffen bis zu 3 Jahre. Danach wechseln viele Eltern zur normalen Badewanne mit Badewannensitz oder einem Anti-Rutsch-Einsatz.'
  },
  {
    question: 'Brauche ich ein extra Badethermometer wenn die Wanne einen Temperatursensor hat?',
    answer: 'Die eingebauten Temperatursensoren (Farbwechsel-Stöpsel) sind ein guter <strong>erster Anhaltspunkt</strong>, aber nicht immer präzise genug. Wir empfehlen zusätzlich ein digitales Badethermometer &ndash; es kostet nur 5-10€ und gibt dir die Sicherheit, dass das Wasser exakt <strong>37°C</strong> hat.'
  },
  {
    question: 'Ist ein Gestell wirklich nötig?',
    answer: 'Nicht zwingend &ndash; aber gerade in den <strong>ersten Wochen nach der Geburt</strong> ist ein Gestell Gold wert. Du musst dich nicht auf den Boden knien oder tief bücken. Dein Rücken wird es dir danken, besonders nach einem Kaiserschnitt. Alternativ kannst du eine faltbare Wanne auf den Küchentisch oder die Waschmaschine stellen.'
  },
  {
    question: 'Wo stelle ich die Babywanne am besten hin?',
    answer: 'Am beliebtesten: <strong>im Badezimmer</strong> auf dem Boden oder einem Gestell. Alternativ: auf dem Küchentisch (stabil und rückenschonend) oder im Waschbecken (bei kleinen Babys). Achte darauf, dass die Unterlage rutschfest und eben ist. Im Sommer geht auch der Balkon oder Garten!'
  },
  {
    question: 'Wie viel Wasser kommt in die Babywanne?',
    answer: 'Für Neugeborene reichen ca. <strong>10-15 cm Wasserstand</strong> &ndash; das Wasser sollte bis zum Bauchnabel reichen, wenn dein Baby liegt. Zu viel Wasser ist gefährlich und auch gar nicht nötig. Immer erst kaltes, dann warmes Wasser einfüllen und auf <strong>37°C</strong> testen.'
  },
];
---

<BaseLayout
  title="Babywanne Test 2026: Die 5 besten Babybadewannen im Vergleich"
  description="Welche Babywanne ist die beste? Wir vergleichen 5 beliebte Modelle 2026 &ndash; faltbar und mit Gestell. Mit ehrlicher Kaufberatung und Praxistipps."
>
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <Breadcrumb items={[
      { label: 'Produkte', href: '/produkte/' },
      { label: 'Babywannen' }
    ]} />

    <!-- Intro -->
    <header class="mb-10">
      <span class="inline-block px-3 py-1 text-xs font-heading font-semibold bg-primary/10 text-primary-dark rounded-full mb-4">Produktvergleich</span>
      <h1 class="font-heading text-3xl md:text-4xl font-extrabold leading-tight mb-5">Babywanne Test 2026: Die 5 besten Babybadewannen</h1>
      <p class="text-text-light text-lg leading-relaxed mb-4">
        Eine gute Babywanne macht das Baden sicher und bequem &ndash; für dein Baby <strong>und</strong> für dich. Aber welche passt zu euch? <strong>Faltbar</strong> für kleine Bäder und Reisen? Oder mit <strong>Gestell</strong>, damit dein Rücken geschont wird? Wir haben die 5 beliebtesten Modelle verglichen und zeigen dir, worauf es wirklich ankommt.
      </p>
      <p class="text-sm text-text-light italic">
        <em>Zuletzt aktualisiert: Februar 2026</em>
      </p>
    </header>

    <!-- Quick Navigation -->
    <nav class="mb-12 bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
      <h2 class="font-heading font-bold text-lg mb-4">&#128203; Auf dieser Seite</h2>
      <div class="grid sm:grid-cols-2 gap-2 text-sm">
        <a href="#vergleich" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Vergleichstabelle (alle 5 Modelle)
        </a>
        <a href="#faltbar" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Faltbare Babywannen (3 Modelle)
        </a>
        <a href="#gestell" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Babywannen mit Gestell (2 Modelle)
        </a>
        <a href="#kaufberatung" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Kaufberatung & Checkliste
        </a>
      </div>
    </nav>

    <!-- Vergleichstabelle -->
    <section id="vergleich" class="mb-14">
      <h2 class="font-heading text-2xl font-extrabold mb-6">Die 5 besten Babywannen auf einen Blick</h2>
      <ComparisonTable products={products} />
    </section>

    <!-- ==================== -->
    <!-- 1. FALTBARE BABYWANNEN -->
    <!-- ==================== -->
    <section id="faltbar" class="mb-14">
      <h2 class="font-heading text-2xl font-extrabold mb-6">Faltbare Babywannen</h2>
      <p class="text-text-light leading-relaxed mb-6">
        Faltbare Babywannen sind die <strong>beliebteste Wahl</strong> für junge Familien: Sie lassen sich nach dem Baden platzsparend zusammenklappen, sind leicht zu transportieren und deutlich günstiger als Gestell-Varianten. Perfekt für kleine Badezimmer, Mietwohnungen und Reisen. Alle drei Modelle bestehen aus <strong>BPA-freiem PP+TPE-Material</strong> und haben rutschfeste Standfüße.
      </p>

      <!-- 1. FawnsLife -->
      <h3 class="font-heading font-bold text-xl mt-8 mb-3">1. FawnsLife Babywanne faltbar mit Knieschutz</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Die <strong>FawnsLife Babywanne</strong> ist unser Testsieger &ndash; und das hat einen guten Grund: Sie ist die einzige faltbare Wanne mit einem <strong>mitgelieferten Knieschutz für Eltern</strong>. Wer schon einmal 15 Minuten auf dem harten Badezimmerboden gekniet hat, weiß dieses Detail zu schätzen. Das Premium PP+TPE-Material ist robust, BPA-frei und die Wanne klappt in Sekunden zusammen. Rutschfeste Füße, auslaufsicherer Verschluss und ein cleveres Design machen sie zum Rundum-Sorglos-Paket.
      </p>
      <AmazonProductBox
        name="FawnsLife Babywanne faltbar mit Knieschutz"
        affiliateLink={`https://www.amazon.de/dp/B0CGXLRJQ3?tag=${AMAZON_TAG}`}
        features={[
          'Premium PP+TPE Material &ndash; BPA-frei und weichmacherfrei',
          'Inkl. Knieschutz für Eltern &ndash; einzigartiges Feature',
          'Kompakt faltbar in Sekunden &ndash; ideal für kleine Bäder und Reisen',
          'Rutschfeste Füße und rutschfester Wannenboden',
          'Auslaufsicherer Verschluss und stabile Verarbeitung'
        ]}
        rating="4,6/5"
        badge="Testsieger"
        image="/images/products/fawnslife-babywanne.jpg"
      />
      <MamaTipp text="Das Besondere an der FawnsLife: Der mitgelieferte Knieschutz für Eltern ist ein echtes Highlight. Wenn du auf dem Badezimmerboden kniend badest, wirst du das lieben! Mein Tipp: Wanne auf eine Anti-Rutsch-Matte in die Dusche stellen &ndash; so ist der Boden gleich geschützt." />

      <!-- 2. Stützkissen & Temperatursensor -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">2. Faltbare Babywanne mit Stützkissen & Temperatursensor</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Diese faltbare Babywanne ist besonders für <strong>Neugeborene</strong> ideal: Das mitgelieferte <strong>weiche Stützkissen</strong> gibt kleinen Babys sicheren Halt und sorgt für eine ergonomische Liegeposition. Der Temperatursensor im Abflussstöpsel wechselt die Farbe, wenn das Wasser über 40°C ist &ndash; ein einfacher Sicherheitscheck auf einen Blick. Leicht, faltbar und aufhängbar.
      </p>
      <AmazonProductBox
        name="Faltbare Babybadewanne mit Stützkissen & Temperatursensor"
        affiliateLink={`https://www.amazon.de/dp/B0BB1Y5K36?tag=${AMAZON_TAG}`}
        features={[
          'Weiches Stützkissen für Neugeborene inklusive',
          'Temperatursensor im Abflussstöpsel (Farbwechsel über 40°C)',
          'Faltbar und mit Aufhängehaken &ndash; platzsparend verstaubar',
          'Umweltfreundliches PP+TPE Material, geruchsfrei',
          'Rutschfeste Standfüße für sicheren Halt'
        ]}
        rating="4,5/5"
        badge="Für Neugeborene"
        image="/images/products/glenmore-babywanne.jpg"
      />

      <!-- 3. XXL mit Thermometer -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">3. Faltbare XXL-Babywanne mit Thermometer (3 Stufen)</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Wenn du eine Wanne suchst, die <strong>möglichst lange mitwächst</strong>, ist die XXL-Variante die richtige Wahl. Das clevere <strong>3-Stufen-Design</strong> passt sich dem Alter deines Babys an: Stufe 1 für Neugeborene (liegend), Stufe 2 für Sitzer (ab 6 Monate), Stufe 3 für Kleinkinder (bis 3 Jahre). Das integrierte digitale Thermometer zeigt die Wassertemperatur präzise an &ndash; kein Extra-Thermometer nötig.
      </p>
      <AmazonProductBox
        name="Faltbare Babybadewanne XXL mit Thermometer (3-Stufen)"
        affiliateLink={`https://www.amazon.de/dp/B0B9HQDZ6H?tag=${AMAZON_TAG}`}
        features={[
          'XXL-Größe &ndash; wächst mit deinem Baby mit (0-3 Jahre)',
          'Integriertes digitales Thermometer &ndash; kein Extra-Gerät nötig',
          '3-Stufen-Design für Neugeborene, Sitzer und Kleinkinder',
          'Rutschfestes Badekissen für sicheres Liegen inklusive',
          'Faltbar und leicht zu verstauen'
        ]}
        rating="4,4/5"
        badge="Wächst mit"
        image="/images/products/xxl-babywanne-thermometer.jpg"
      />
    </section>

    <!-- ==================== -->
    <!-- 2. BABYWANNEN MIT GESTELL -->
    <!-- ==================== -->
    <section id="gestell" class="mb-14">
      <h2 class="font-heading text-2xl font-extrabold mb-6">Babywannen mit Gestell</h2>
      <p class="text-text-light leading-relaxed mb-6">
        Eine Babywanne mit Gestell bringt dein Baby auf <strong>bequeme Bauchhöhe</strong> &ndash; kein Bücken, kein Knien, kein Rückenschmerzen. Besonders nach einem Kaiserschnitt oder einer anstrengenden Geburt ist das ein echter Gamechanger. Beide Modelle sind stabil, TÜV-geprüft und bieten genug Platz zum Planschen.
      </p>

      <!-- 4. Babykajo -->
      <h3 class="font-heading font-bold text-xl mt-8 mb-3">4. Babykajo Babywanne mit Gestell (4er-Set, TÜV-zertifiziert)</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Das <strong>Babykajo 4er-Set</strong> ist das Komplettpaket für sicherheitsbewusste Eltern: <strong>TÜV Rheinland zertifiziert</strong>, mit stabilem Metallgestell, großer 86-cm-Wanne, Anti-Rutsch-Badewannensitz und Abflussschlauch. Alles dabei, nichts extra kaufen. Das Gestell bringt die Wanne auf eine rückenschonende Höhe und steht dabei bombenfest.
      </p>
      <AmazonProductBox
        name="Babykajo Babywanne mit Gestell (4er-Set, TÜV-zertifiziert)"
        affiliateLink={`https://www.amazon.de/dp/B07X2TFZCL?tag=${AMAZON_TAG}`}
        features={[
          'TÜV Rheinland zertifiziert &ndash; geprüfte Sicherheit',
          'Komplettset: Wanne + Gestell + Badewannensitz + Abflussschlauch',
          '86 cm große Wanne &ndash; genug Platz zum Planschen',
          'Stabiles Metallgestell &ndash; rückenschonend auf Bauchhöhe',
          'Anti-Rutsch-Badewannensitz für sicheren Halt inklusive'
        ]}
        rating="4,4/5"
        badge="TÜV-geprüft"
        image="/images/products/babykajo-babywanne-gestell.jpg"
      />

      <!-- 5. moovkee -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">5. moovkee Babybadewanne mit Gestell &ndash; Premium</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Die <strong>moovkee</strong> ist die Premium-Wahl für Eltern, die das Beste wollen: Ein <strong>LCD-Thermometer mit 0,1°C Genauigkeit</strong> zeigt die Wassertemperatur in Echtzeit an, das ergonomische Badekissen gibt deinem Baby sicheren Halt, und der praktische Duschkopf-Halter am Wannenrand macht das Abspülen leicht. Das faltbare Gestell bringt die Wanne auf 84,5 cm &ndash; perfekte Arbeitshöhe.
      </p>
      <AmazonProductBox
        name="moovkee Babybadewanne mit Gestell 80cm"
        affiliateLink={`https://www.amazon.de/dp/B0CDLWBNW1?tag=${AMAZON_TAG}`}
        features={[
          'LCD-Thermometer mit 0,1°C Genauigkeit &ndash; Echtzeit-Anzeige',
          'Ergonomisches Badekissen für sicheres Liegen',
          'Stabiles Faltgestell (84,5 cm Höhe) &ndash; rückenschonend',
          'Duschkopf-Halter am Wannenrand &ndash; praktisch zum Abspülen',
          'Bis 30 kg belastbar &ndash; nutzbar bis 36 Monate'
        ]}
        rating="4,3/5"
        badge="Premium"
        image="/images/products/moovkee-babywanne-gestell.jpg"
      />

      <MamaTipp text="Nach einem Kaiserschnitt oder einer schweren Geburt ist eine Babywanne mit Gestell wirklich Gold wert. Du musst dich nicht bücken und kannst dein Baby in bequemer Höhe baden. Die Babykajo ist das beste Preis-Leistungs-Verhältnis, die moovkee die Premium-Wahl mit Thermometer." />
    </section>

    <!-- ==================== -->
    <!-- KAUFBERATUNG -->
    <!-- ==================== -->
    <section id="kaufberatung" class="mb-12">
      <h2 class="font-heading text-2xl font-extrabold mb-6">Kaufberatung: Welche Babywanne passt zu dir?</h2>

      <!-- Faltbar vs. Gestell -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
          <h3 class="font-heading font-bold text-lg mb-3">&#128704; Faltbare Babywanne</h3>
          <ul class="text-sm text-text-light space-y-2">
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Platzsparend, ideal für kleine Bäder</li>
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Leicht und transportabel (Reisen!)</li>
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Günstiger</li>
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Schnell auf- und abgebaut</li>
            <li class="flex items-start gap-2"><span class="text-red-500">&#10007;</span> Du musst dich bücken oder knien</li>
            <li class="flex items-start gap-2"><span class="text-red-500">&#10007;</span> Weniger stabil als Gestell-Varianten</li>
          </ul>
          <p class="mt-3 text-xs text-primary-dark font-heading font-bold">Empfehlung: FawnsLife (Testsieger)</p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
          <h3 class="font-heading font-bold text-lg mb-3">&#128690; Babywanne mit Gestell</h3>
          <ul class="text-sm text-text-light space-y-2">
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Rückenschonend &ndash; Baby auf Bauchhöhe</li>
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Sehr stabil und sicher</li>
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Ideal nach Kaiserschnitt</li>
            <li class="flex items-start gap-2"><span class="text-green-600">&#10003;</span> Oft mit Zubehör (Sitz, Ablauf)</li>
            <li class="flex items-start gap-2"><span class="text-red-500">&#10007;</span> Braucht mehr Platz</li>
            <li class="flex items-start gap-2"><span class="text-red-500">&#10007;</span> Teurer</li>
          </ul>
          <p class="mt-3 text-xs text-primary-dark font-heading font-bold">Empfehlung: Babykajo (TÜV-geprüft)</p>
        </div>
      </div>

      <!-- Checkliste -->
      <h3 class="font-heading font-bold text-xl mb-4">&#9989; Checkliste: Worauf du beim Kauf achten solltest</h3>
      <div class="bg-white rounded-2xl p-6 border border-primary/10 shadow-sm mb-8">
        <ul class="space-y-3 text-text-light">
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold text-lg">1.</span>
            <span><strong>Material:</strong> BPA-frei und weichmacherfrei (PP+TPE sind ideal). Auf unangenehmen Plastikgeruch achten &ndash; bei Qualitätsprodukten gibt es keinen.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold text-lg">2.</span>
            <span><strong>Rutschfestigkeit:</strong> Standfüße mit Gummi UND rutschfester Wannenboden sind ein Muss. Ohne rutscht dein Baby und die Wanne gleitet auf nassen Fliesen weg.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold text-lg">3.</span>
            <span><strong>Abfluss:</strong> Ein Stöpsel oder besser noch ein Abflussschlauch erleichtert das Entleeren enorm. Ohne Abfluss musst du die volle Wanne kippen &ndash; schwer und unpraktisch.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold text-lg">4.</span>
            <span><strong>Größe:</strong> Miss vorher dein Badezimmer aus! Die Wanne muss reinpassen &ndash; aufgebaut UND zusammengeklappt (Stauraum). Bedenke auch die Tür- und Duschbreite.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold text-lg">5.</span>
            <span><strong>Altersbereich:</strong> 0-12 Monate reicht für den Anfang. Wenn du die Wanne länger nutzen willst, wähle ein XXL-Modell (0-36 Monate).</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold text-lg">6.</span>
            <span><strong>Temperaturanzeige:</strong> Eingebaute Farbwechsel-Stöpsel sind nett, aber kein Ersatz für ein echtes Badethermometer. LCD-Displays (wie bei moovkee) sind deutlich präziser.</span>
          </li>
        </ul>
      </div>

      <!-- Praxis-Tipps -->
      <h3 class="font-heading font-bold text-xl mb-4">&#128161; Praxis-Tipps für das erste Bad</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-white rounded-2xl p-5 border border-green-200 shadow-sm">
          <h4 class="font-heading font-bold text-sm mb-2 text-green-800">Vor dem Baden</h4>
          <ul class="text-xs text-text-light space-y-1">
            <li>&bull; Alles in Griffweite legen (Handtuch, Waschlappen, Kleidung)</li>
            <li>&bull; Raumtemperatur: 22-24°C (zugfrei!)</li>
            <li>&bull; Wasser: erst kalt, dann warm &ndash; auf 37°C testen</li>
            <li>&bull; Wasserstand: 10-15 cm (bis Bauchnabel)</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl p-5 border border-primary/10 shadow-sm">
          <h4 class="font-heading font-bold text-sm mb-2">Beim Baden</h4>
          <ul class="text-xs text-text-light space-y-1">
            <li>&bull; Baby immer mit einer Hand festhalten</li>
            <li>&bull; Zuerst Gesicht, dann Körper, zum Schluss Po</li>
            <li>&bull; Badedauer: 5-10 Minuten reichen</li>
            <li>&bull; Nie allein lassen &ndash; auch nicht kurz!</li>
          </ul>
        </div>
      </div>
    </section>

    <WichtigHinweis text="Lass dein Baby NIEMALS allein in der Babywanne &ndash; auch nicht für einen kurzen Moment. Schon 2 cm Wasser können für ein Baby gefährlich werden. Bereite alles vor dem Baden vor (Handtuch, Kleidung, Windel), damit du nicht weggehen musst. Lass das Telefon klingeln &ndash; dein Baby geht vor!" />

    <!-- FAQ -->
    <section class="mb-12 mt-12">
      <h2 class="font-heading text-2xl font-extrabold mb-6">Häufige Fragen zu Babywannen</h2>
      <FAQ items={faqItems} />
    </section>

    <!-- Fazit -->
    <section class="mb-8">
