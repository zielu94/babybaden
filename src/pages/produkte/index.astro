---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Babywannen',
    description: 'Die besten Babybadewannen im Vergleich &ndash; faltbar, mit Gestell und für Neugeborene.',
    href: '/produkte/babywannen/',
    icon: '&#128705;',
  },
  {
    title: 'Badethermometer',
    description: 'Digitale und analoge Thermometer für die perfekte Badetemperatur.',
    href: '/produkte/badethermometer/',
    icon: '&#127777;&#65039;',
  },
  {
    title: 'Heizstrahler',
    description: 'Wärmelampen für den Wickeltisch &ndash; damit dein Baby nach dem Baden nicht friert.',
    href: '/produkte/heizstrahler/',
    icon: '&#9728;&#65039;',
  },
  {
    title: 'Badezubehör',
    description: 'Waschlappen, Kapuzenhandtücher und alles was du sonst noch brauchst.',
    href: '/produkte/badezubehoer/',
    icon: '&#128166;',
  },
  {
    title: 'Pflegeprodukte',
    description: 'Sanfte Cremes, Öle und Shampoos für empfindliche Babyhaut.',
    href: '/produkte/pflegeprodukte/',
    icon: '&#129524;',
  },
  {
    title: 'Badespielzeug',
    description: 'Badeenten, Stapelbecher und Wasserspielzeug für fröhlichen Badespaß.',
    href: '/produkte/badespielzeug/',
    icon: '&#129414;',
  },
];
---

<BaseLayout
  title="Produkte für das Baby-Baden"
  description="Die besten Produkte für das Baby-Baden im Vergleich: Babywannen, Thermometer, Heizstrahler und mehr."
>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="font-heading text-3xl md:text-4xl font-extrabold text-center mb-4">Produkte</h1>
    <p class="text-center text-text-light max-w-2xl mx-auto mb-8">
      Unsere ehrlichen Produktvergleiche helfen dir, die richtige Ausstattung für das Baby-Baden zu finden.
    </p>

    <!-- Starter Set Highlight -->
    <a href="/produkte/starter-set/" class="group block bg-gradient-to-r from-primary/10 to-accent/10 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-md border border-primary/10 transition-all mb-8">
      <div class="flex items-center gap-4">
        <span class="text-4xl">&#127873;</span>
        <div>
          <span class="inline-block px-2 py-0.5 text-[10px] font-heading font-bold bg-accent text-text rounded-full mb-1">NEU</span>
          <h2 class="font-heading font-bold text-xl group-hover:text-primary-dark transition-colors">Starter Set – Die komplette Erstausstattung</h2>
          <p class="mt-1 text-sm text-text-light">Alles was du für das erste Baby-Bad brauchst – unsere Top-Empfehlungen auf einen Blick.</p>
        </div>
        <svg class="w-6 h-6 text-primary-dark flex-shrink-0 ml-auto group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </a>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map(cat => (
        <a href={cat.href} class="group block bg-white rounded-2xl p-6 shadow-sm hover:shadow-md border border-primary/10 transition-all">
          <span class="text-3xl block mb-3" set:html={cat.icon} />
          <h2 class="font-heading font-bold text-lg group-hover:text-primary-dark transition-colors">{cat.title}</h2>
          <p class="mt-2 text-sm text-text-light" set:html={cat.description} />
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
