---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import AmazonProductBox from '../../components/AmazonProductBox.astro';
import MamaTipp from '../../components/MamaTipp.astro';
import WichtigHinweis from '../../components/WichtigHinweis.astro';
import FAQ from '../../components/FAQ.astro';

const AMAZON_TAG = 'jalapeno123-21';

const products = [
  { name: 'reer EasyHeat Flex', feature: '500W, kompakt (46cm), Wand/Stand, Medizinstandard', rating: '4,4', price: 'ca. 80 €', recommended: true, affiliateLink: `https://www.amazon.de/dp/B07FM6WLYW?tag=${AMAZON_TAG}` },
  { name: 'reer HeatCare+ Flex', feature: 'EcoHeat Carbon, 350/700W, Fernbedienung, Premium', rating: '4,2', price: 'ca. 120 €', affiliateLink: `https://www.amazon.de/dp/B0FQP3BMJ8?tag=${AMAZON_TAG}` },
  { name: 'Babyruf BR-80', feature: '400/800W, Wand/Stand, schwenk- & höhenverstellbar', rating: '4,2', price: 'ca. 90 €', affiliateLink: `https://www.amazon.de/dp/B0B6T5W938?tag=${AMAZON_TAG}` },
  { name: 'Babyruf BR-60', feature: '600W, Wandmontage, Abschaltautomatik, TÜV-geprüft', rating: '4,3', price: 'ca. 25 €', affiliateLink: `https://www.amazon.de/dp/B0CXJBNNB4?tag=${AMAZON_TAG}` },
  { name: 'tectake Infrarot 2000W', feature: '3 Stufen, 2000W, Wand/Stand, Kippschutz', rating: '4,4', price: 'ca. 60 €', affiliateLink: `https://www.amazon.de/dp/B0D4DZYNFF?tag=${AMAZON_TAG}` },
];

const faqItems = [
  {
    question: 'Brauche ich wirklich einen Heizstrahler am Wickeltisch?',
    answer: 'Besonders in den kälteren Monaten ist ein Heizstrahler sehr empfehlenswert. Babys können ihre Körpertemperatur noch nicht gut regulieren und kühlen nach dem warmen Bad schnell aus. Ein Heizstrahler sorgt für angenehme Wärme beim Abtrocknen, Eincremen und Anziehen &ndash; und dein Baby weint weniger, weil es sich wohler fühlt.'
  },
  {
    question: 'Wandmontage oder Standgerät &ndash; was ist besser?',
    answer: 'Wandmontage ist platzsparender und sicherer (kein Umkippen möglich). Standgeräte sind flexibler und ideal für Mietwohnungen, in denen du nicht bohren möchtest. Die beste Lösung: Ein 2-in-1-Gerät wie der reer HeatCare+ Flex oder der Babyruf BR-80, das beides kann.'
  },
  {
    question: 'Wie weit muss der Heizstrahler vom Baby entfernt sein?',
    answer: 'Mindestens 80-100 cm Abstand zum Baby &ndash; das ist die goldene Regel. Beachte immer die Herstellerangaben deines Modells. Teste die Wärme vor dem ersten Einsatz mit deiner eigenen Hand auf der Wickelfläche: Es sollte sich angenehm warm anfühlen, aber auf keinen Fall heiß.'
  },
  {
    question: 'Kann ich einen normalen Heizstrahler (Terrasse/Bad) verwenden?',
    answer: 'Wir raten dringend davon ab. Baby-Heizstrahler sind speziell für den Einsatz am Wickeltisch konzipiert. Sie haben Abschaltautomatiken, Spritzwasserschutz und strahlen eine gleichmäßige, sichere Wärme ab. Normale Heizstrahler können zu heiß werden und haben keine Sicherheitsfunktionen für den Einsatz in Babynähe.'
  },
  {
    question: 'Wie lange braucht man einen Heizstrahler?',
    answer: 'Die meisten Familien nutzen den Heizstrahler, bis das Kind etwa 2-3 Jahre alt ist. Danach können sich Kinder in der Regel schnell genug anziehen und frieren weniger leicht nach dem Baden. Im Winter ist er aber auch danach noch praktisch.'
  },
  {
    question: 'Was bedeutet die Watt-Angabe?',
    answer: 'Die Wattzahl gibt die Heizleistung an. 500-600W reicht für den Wickeltisch völlig aus und ist dabei energiesparend. 800W oder mehr erzeugt schneller Wärme, verbraucht aber auch mehr Strom. Für einen normalen Wickelplatz empfehlen wir 500-700W &ndash; das ist der Sweet Spot zwischen Wärme und Stromverbrauch.'
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Die 5 besten Heizstrahler f\u00fcr den Wickeltisch 2026',
  description: 'Vergleich der beliebtesten Baby-Heizstrahler f\u00fcr Wickeltisch auf Amazon.',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: p.affiliateLink,
  })),
};
---

<BaseLayout
  title="Heizstrahler Baby Wickeltisch: Die 5 besten im Test 2026"
  description="Heizstrahler Wickeltisch Test 2026: reer, Babyruf & tectake im Vergleich. Wandmontage vs. Standger&auml;t, Sicherheitstipps &amp; Testsieger ab 33&euro;."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <Breadcrumb items={[
      { label: 'Produkte', href: '/produkte/' },
      { label: 'Heizstrahler' }
    ]} />

    <!-- Intro -->
    <header class="mb-10">
      <span class="inline-block px-3 py-1 text-xs font-heading font-semibold bg-primary/10 text-primary-dark rounded-full mb-4">Produktvergleich</span>
      <h1 class="font-heading text-3xl md:text-4xl font-extrabold leading-tight mb-5">Heizstrahler Baby Wickeltisch: Die 5 besten im Test 2026</h1>
      <p class="text-text-light text-lg leading-relaxed mb-4">
        Nach dem warmen Bad f&auml;llt die K&ouml;rpertemperatur deines Babys schnell ab. <strong>Babys k&ouml;nnen ihre Temperatur noch nicht selbst regulieren</strong> &ndash; deshalb ist ein Heizstrahler am Wickeltisch gerade im Winter ein echtes Must-have.
      </p>
      <p class="text-text-light leading-relaxed mb-4">
        Wir haben die <strong>5 beliebtesten Wickeltisch-Heizstrahler</strong> verglichen: vom bew&auml;hrten Testsieger (reer EasyHeat, ~80&euro;) bis zum Premium-Modell mit Fernbedienung (reer HeatCare+ Flex, ~120&euro;). Wandmontage, Standger&auml;te und flexible 2-in-1-L&ouml;sungen &ndash; f&uuml;r jeden Wickelplatz das Richtige.
      </p>
      <p class="text-sm text-text-light italic">
        <em>Zuletzt aktualisiert: M&auml;rz 2026</em>
      </p>
    </header>

    <!-- Sicherheits-Icons -->
    <section class="mb-10">
      <div class="bg-white rounded-2xl p-5 md:p-6 border border-primary/10 shadow-sm">
        <h2 class="font-heading font-bold text-lg mb-4 text-center">&#128272; Sicherheits-Checkliste f&uuml;r Baby-Heizstrahler</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div class="p-3 rounded-xl bg-green-50 border border-green-200">
            <span class="text-2xl block mb-1">&#128274;</span>
            <span class="text-xs font-heading font-bold text-green-800">Kippschutz</span>
            <p class="text-[10px] text-text-light mt-0.5">Auto-Abschaltung bei Umfallen</p>
          </div>
          <div class="p-3 rounded-xl bg-green-50 border border-green-200">
            <span class="text-2xl block mb-1">&#9201;</span>
            <span class="text-xs font-heading font-bold text-green-800">Auto-Off Timer</span>
            <p class="text-[10px] text-text-light mt-0.5">Abschaltung nach 10 Min.</p>
          </div>
          <div class="p-3 rounded-xl bg-green-50 border border-green-200">
            <span class="text-2xl block mb-1">&#128207;</span>
            <span class="text-xs font-heading font-bold text-green-800">T&Uuml;V / GS</span>
            <p class="text-[10px] text-text-light mt-0.5">Gepr&uuml;fte Sicherheit</p>
          </div>
          <div class="p-3 rounded-xl bg-green-50 border border-green-200">
            <span class="text-2xl block mb-1">&#128207;</span>
            <span class="text-xs font-heading font-bold text-green-800">80-100 cm</span>
            <p class="text-[10px] text-text-light mt-0.5">Mindestabstand zum Baby</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testsieger Highlight -->
    <section class="mb-12">
      <div class="text-center mb-6">
        <span class="inline-block px-4 py-1.5 text-sm font-heading font-bold bg-yellow-400 text-yellow-900 rounded-full shadow-sm">&#127942; Unser Testsieger 2026</span>
      </div>
      <div class="relative bg-white rounded-2xl border-2 border-yellow-400 p-5 md:p-6 shadow-md">
        <span class="absolute -top-3 left-4 inline-block px-3 py-1 text-xs font-heading font-bold bg-yellow-400 text-yellow-900 rounded-full shadow-sm">&#127942; Testsieger Preis-Leistung</span>
        <div class="flex flex-col sm:flex-row gap-5 mt-2">
          <div class="flex-shrink-0 w-full sm:w-40 h-40 bg-primary/5 rounded-xl flex items-center justify-center overflow-hidden">
            <img src="/images/products/reer-easyheat-heizstrahler.jpg" alt="reer EasyHeat Flex Wickeltisch-Heizstrahler" class="w-full h-full object-contain" loading="eager" />
          </div>
          <div class="flex-1">
            <h2 class="font-heading font-bold text-xl leading-snug">reer EasyHeat Flex</h2>
            <p class="text-sm text-text-light mt-1">500W, kompakt (46 cm), Wand/Stand, nach Medizinstandard gepr&uuml;ft</p>
            <div class="mt-2 flex flex-wrap items-center gap-3">
              <span class="text-sm text-text-light">&#11088; 4,4/5 (Amazon)</span>
              <span class="text-sm font-heading font-semibold text-primary-dark">ca. 80 &euro;</span>
            </div>
            <ul class="mt-3 space-y-1 text-sm text-text-light">
              <li class="flex items-start gap-2"><span class="text-yellow-500">&#10003;</span> 2-in-1: Wandmontage ODER Standfuss</li>
              <li class="flex items-start gap-2"><span class="text-yellow-500">&#10003;</span> Kippschutz + &Uuml;berhitzungsschutz + Auto-Off</li>
              <li class="flex items-start gap-2"><span class="text-yellow-500">&#10003;</span> Bew&auml;hrte Qualit&auml;t &ndash; &uuml;ber 1.600 Bewertungen</li>
            </ul>
            <a
              href={`https://www.amazon.de/dp/B07FM6WLYW?tag=${AMAZON_TAG}`}
              target="_blank"
              rel="nofollow noopener sponsored"
              class="mt-4 inline-flex items-center justify-center gap-2 px-7 py-3 bg-[#FF9900] hover:bg-[#E8860D] text-white font-heading font-bold text-sm rounded-full transition-colors shadow-md hover:shadow-lg"
            >
              Testsieger auf Amazon ansehen
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Navigation -->
    <nav class="mb-12 bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
      <h2 class="font-heading font-bold text-lg mb-4">&#128203; Auf dieser Seite</h2>
      <div class="grid sm:grid-cols-2 gap-2 text-sm">
        <a href="#vergleich" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Vergleichstabelle (alle 5 Modelle)
        </a>
        <a href="#testsieger" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> &#127942; Testsieger: reer EasyHeat Flex
        </a>
        <a href="#alternativen" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> 4 Alternativen im Detail
        </a>
        <a href="#kaufberatung" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Kaufberatung: Wand vs. Stand
        </a>
        <a href="#faq" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> H&auml;ufige Fragen (FAQ)
        </a>
      </div>
    </nav>

    <!-- Sicherheitshinweis -->
    <WichtigHinweis text="Halte immer mindestens 80-100 cm Abstand zwischen Heizstrahler und Baby. Lass den Heizstrahler nie unbeaufsichtigt laufen und achte auf eine automatische Abschaltfunktion. Teste die W&auml;rme vor dem ersten Einsatz mit deiner eigenen Hand." />

    <!-- Vergleichstabelle -->
    <section id="vergleich" class="mb-12">
      <h2 class="font-heading text-2xl font-extrabold mb-6">Alle 5 Heizstrahler auf einen Blick</h2>
      <ComparisonTable products={products} />
    </section>

    <!-- 1. reer EasyHeat Flex -->
    <section id="testsieger" class="mb-12">
      <h2 class="font-heading text-2xl font-extrabold mb-4">1. reer EasyHeat Flex &ndash; &#127942; Testsieger</h2>
      <p class="text-text-light leading-relaxed mb-6">
        Der <strong>reer EasyHeat Flex</strong> ist der Klassiker unter den Baby-Heizstrahlern. Mit nur <strong>46 cm Breite</strong> passt er auch in die kleinsten Badezimmer. Die 500W Heizleistung reicht für den Wickeltisch völlig aus und ist dabei besonders <strong>energiesparend</strong>. Dank des <strong>modularen Standfußes</strong> lässt er sich sowohl an der Wand montieren als auch frei neben den Wickeltisch stellen &ndash; ideal für Mietwohnungen.
      </p>

      <AmazonProductBox
        name="reer EasyHeat Flex Wickeltischstrahler"
        affiliateLink={`https://www.amazon.de/dp/B07FM6WLYW?tag=${AMAZON_TAG}`}
        features={[
          'Kompakt: Nur 46 cm breit &ndash; perfekt für kleine Räume',
          '500W &ndash; energiesparend und trotzdem leistungsstark',
          '2-in-1: Wandmontage ODER mit höhenverstellbarem Standfuß',
          'Geprüft nach Medizinstandard (Teilprüfung IEC 60601-2-21)',
          'Abschaltautomatik nach 10 Minuten',
          'Kipp-Abschaltung und Überhitzungsschutz'
        ]}
        rating="4,4/5"
        price="ca. 80 €"
        badge="&#127942; Testsieger"
        image="/images/products/reer-easyheat-heizstrahler.jpg"
        imageFit="contain"
      />

      <div class="mt-4 grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 rounded-xl p-4 border border-green-200">
          <h4 class="font-heading font-bold text-sm text-green-800 mb-2">&#10004; Was uns gefällt</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; Bew&auml;hrte Qualit&auml;t (~80€)</li>
            <li>&bull; Kompakt &ndash; ideal für kleine Bäder</li>
            <li>&bull; Flexibel: Wand oder Stand</li>
            <li>&bull; Nach Medizinstandard geprüft</li>
            <li>&bull; Über 1.600 positive Bewertungen</li>
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-4 border border-red-200">
          <h4 class="font-heading font-bold text-sm text-red-800 mb-2">&#10008; Bedenken</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; Standfuß nicht immer 100% stabil</li>
            <li>&bull; Eher kurzes Kabel</li>
            <li>&bull; Nur eine Heizstufe (500W)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 2. reer HeatCare+ Flex -->
    <section id="alternativen" class="mb-12">
      <h2 class="font-heading text-2xl font-extrabold mb-4">2. reer HeatCare+ Flex &ndash; Das Premium-Modell</h2>
      <p class="text-text-light leading-relaxed mb-6">
        Der <strong>reer HeatCare+ Flex</strong> ist das Topmodell von reer mit innovativer <strong>EcoHeat Carbon-Technologie</strong>. Er heizt in nur 5-6 Sekunden auf und verbraucht dabei 12,5% weniger Energie als vergleichbare Modelle. Die <strong>Fernbedienung</strong> ist im Alltag ein echtes Plus &ndash; besonders wenn du dein Baby auf dem Arm hast. Als 2-in-1-Gerät lässt er sich an die Wand montieren oder mit Standfuß frei aufstellen.
      </p>

      <AmazonProductBox
        name="reer HeatCare+ Flex Wickeltisch-Heizstrahler"
        affiliateLink={`https://www.amazon.de/dp/B0FQP3BMJ8?tag=${AMAZON_TAG}`}
        features={[
          'EcoHeat Carbon-Heizelement &ndash; Wärme in 5-6 Sekunden',
          '2 Heizstufen: 350W und 700W',
          '12,5% weniger Energieverbrauch als Vergleichsmodelle',
          'Fernbedienung mit klaren Symbolen',
          '2-in-1: Wand- oder Standgerät (Teleskopstange)',
          'Zuschaltbare Timer-Funktion',
          'GS-zertifizierter Kippschutz'
        ]}
        rating="4,2/5"
        price="ca. 120 €"
        badge="Premium-Empfehlung"
        image="/images/products/reer-heatcare-flex-heizstrahler.jpg"
      />

      <div class="mt-4 grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 rounded-xl p-4 border border-green-200">
          <h4 class="font-heading font-bold text-sm text-green-800 mb-2">&#10004; Was uns gefällt</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; Schnellste Aufheizzeit (5-6 Sek.)</li>
            <li>&bull; Fernbedienung &ndash; super praktisch</li>
            <li>&bull; Flexibel: Wand oder Stand</li>
            <li>&bull; Energiesparendste Option</li>
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-4 border border-red-200">
          <h4 class="font-heading font-bold text-sm text-red-800 mb-2">&#10008; Bedenken</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; H&ouml;chster Preis im Vergleich (~120€)</li>
            <li>&bull; Standfuß etwas wackelig</li>
            <li>&bull; Relativ neues Modell</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 3. Babyruf BR-80 -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-extrabold mb-4">3. Babyruf BR-80 &ndash; Der Flexible</h2>
      <p class="text-text-light leading-relaxed mb-6">
        Der <strong>Babyruf BR-80</strong> punktet mit seiner <strong>modularen Bauweise</strong>: Er kommt mit Wandhalterung und Standfuß, sodass du flexibel entscheiden kannst. Mit <strong>2 Heizstufen</strong> (400W/800W) lässt sich die Wärme gut dosieren. Besonders praktisch: Er ist <strong>schwenk- und höhenverstellbar</strong> (163-193 cm), sodass du ihn perfekt auf den Wickelplatz ausrichten kannst.
      </p>

      <AmazonProductBox
        name="Babyruf BR-80 Heizstrahler mit Wandhalterung"
        affiliateLink={`https://www.amazon.de/dp/B0B6T5W938?tag=${AMAZON_TAG}`}
        features={[
          '2 Heizstufen: 400W und 800W per Zugschalter',
          'Modulare Montage: Wand ODER Standfuß',
          'Schwenkbar und höhenverstellbar (163-193 cm)',
          'Sicherheitsgeflecht gegen Berührung und Splitter',
          'Zuschaltbare Timer-Funktion',
          'TÜV/GS-geprüft',
          'Leicht: nur 1,54 kg'
        ]}
        rating="4,2/5"
        price="ca. 90 €"
        badge="Flexibelste Lösung"
        image="/images/products/babyruf-br80-heizstrahler.jpg"
        imagePosition="top"
      />

      <div class="mt-4 grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 rounded-xl p-4 border border-green-200">
          <h4 class="font-heading font-bold text-sm text-green-800 mb-2">&#10004; Was uns gefällt</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; 2-in-1: Wand + Stand inklusive</li>
            <li>&bull; Schwenk- und höhenverstellbar</li>
            <li>&bull; 2 Heizstufen für mehr Kontrolle</li>
            <li>&bull; TÜV/GS-geprüft</li>
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-4 border border-red-200">
          <h4 class="font-heading font-bold text-sm text-red-800 mb-2">&#10008; Bedenken</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; Vereinzelt Berichte über defekte Heizstäbe</li>
            <li>&bull; Etwas sperrig für kleine Bäder</li>
            <li>&bull; 800W-Stufe verbraucht relativ viel Strom</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 4. Babyruf BR-60 -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-extrabold mb-4">4. Babyruf BR-60 &ndash; Solide Basis</h2>
      <p class="text-text-light leading-relaxed mb-6">
        Der <strong>Babyruf BR-60</strong> ist ein geradliniger Wickeltisch-Heizstrahler ohne viel Schnickschnack: <strong>600W, Wandmontage, Abschaltautomatik</strong> &ndash; fertig. Er macht geräuschlos sofort Wärme und schaltet sich nach 10 Minuten automatisch ab. Mit einem Schwenkbereich von 65° lässt er sich gut ausrichten. TÜV-geprüft und von einer Marke mit über 20 Jahren Erfahrung.
      </p>

      <AmazonProductBox
        name="Babyruf BR-60 Baby-Heizstrahler 600W"
        affiliateLink={`https://www.amazon.de/dp/B0CXJBNNB4?tag=${AMAZON_TAG}`}
        features={[
          '600W &ndash; geräuschlose, sofortige Wärme',
          'Abschaltautomatik nach 10 Minuten',
          'Schwenkbereich: 65° &ndash; flexibel ausrichtbar',
          'TÜV-geprüft &ndash; über 20 Jahre Babyruf-Erfahrung',
          'Einfache Wandmontage',
          'Kompaktes Design'
        ]}
        rating="4,3/5"
        price="ca. 25 €"
        badge="Solide Basis"
        image="/images/products/babyruf-br60-heizstrahler.jpg"
      />

      <div class="mt-4 grid sm:grid-cols-2 gap-4">
        <div class="bg-green-50 rounded-xl p-4 border border-green-200">
          <h4 class="font-heading font-bold text-sm text-green-800 mb-2">&#10004; Was uns gefällt</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; G&uuml;nstigster Preis (~25€)</li>
            <li>&bull; Geräuschloser Betrieb</li>
            <li>&bull; TÜV-geprüft und bewährt</li>
            <li>&bull; Guter Kundendienst (Babyruf)</li>
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-4 border border-red-200">
          <h4 class="font-heading font-bold text-sm text-red-800 mb-2">&#10008; Bedenken</h4>
          <ul class="text-sm text-text-light space-y-1">
            <li>&bull; Wandhalterung wackelig bei losen Schrauben</li>
            <li>&bull; Nur Wandmontage (kein Standfuß)</li>
            <li>&bull; 10 Min. Abschaltung kann knapp sein</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 5. tectake Infrarot -->
    <section class="mb-12">
