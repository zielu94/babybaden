---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AmazonProductBox from '../../components/AmazonProductBox.astro';
import MamaTipp from '../../components/MamaTipp.astro';
import WichtigHinweis from '../../components/WichtigHinweis.astro';
import FAQ from '../../components/FAQ.astro';

const AMAZON_TAG = 'jalapeno123-21';

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Die 8 besten Baby-Badespielzeuge 2026',
  numberOfItems: 8,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'reer MyHappyBath Toys Ente & Pinguin', url: `https://www.amazon.de/dp/B0D9YBSSZQ?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 2, name: 'BelleStyle Silikon Badetiere 4er-Set', url: `https://www.amazon.de/dp/B0CSFKRMK4?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 3, name: 'Fehn Badetier Otter Theo', url: `https://www.amazon.de/dp/B0D7HGQRCG?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 4, name: 'Fehn Bade-Schwamm Schildkröte', url: `https://www.amazon.de/dp/B09F3MSBM6?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 5, name: 'reer MyHappyBath Book Magisches Badebuch', url: `https://www.amazon.de/dp/B09D8BTCT5?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 6, name: 'Vanmor Saugnapf-Spinner 4er-Set', url: `https://www.amazon.de/dp/B092S24B41?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 7, name: 'PHNIXGAM Wal-Sprinkler mit LED-Licht', url: `https://www.amazon.de/dp/B0D8BTR9FF?tag=${AMAZON_TAG}` },
    { '@type': 'ListItem', position: 8, name: 'Jiosdo DIY-Kugelbahn Badewannenspielzeug', url: `https://www.amazon.de/dp/B0B3RTGW8G?tag=${AMAZON_TAG}` },
  ],
};

const faqItems = [
  {
    question: 'Ab wann ist Badespielzeug sinnvoll?',
    answer: 'Ab etwa <strong>6 Monaten</strong> beginnen Babys, gezielt nach Gegenständen zu greifen und damit zu spielen. Dann macht Badespielzeug richtig Spaß. Weiche Stoff-Badetiere (wie der Fehn Otter) kannst du aber schon ab Geburt anbieten. Elektrisches Spielzeug und Kugelbahnen eignen sich erst ab 1-3 Jahren.'
  },
  {
    question: 'Wie verhindere ich Schimmel im Badespielzeug?',
    answer: 'Das A und O: <strong>Nach jedem Baden das Wasser komplett ausdrücken</strong> und das Spielzeug offen trocknen lassen. Kaufe Spritztiere aus Silikon, die sich zum Reinigen öffnen lassen (wie die reer oder BelleStyle Badetiere). Alle 2 Wochen Spielzeug in einer Essig-Wasser-Lösung (1:3) einweichen und gründlich ausspülen.'
  },
  {
    question: 'Welche Materialien sind unbedenklich für Babys?',
    answer: 'Achte auf <strong>BPA-freien, phthalatfreien Kunststoff</strong>, lebensmittelechtes Silikon oder Naturkautschuk. Stoff-Spielzeug sollte OEKO-TEX-zertifiziert sein. Spielzeug mit CE-Kennzeichnung und idealerweise TÜV-Prüfung ist empfehlenswert. Billiges Importspielzeug ohne Prüfsiegel lieber meiden &ndash; gerade weil Babys alles in den Mund nehmen.'
  },
  {
    question: 'Wie viel Badespielzeug braucht mein Baby?',
    answer: 'Weniger ist mehr! <strong>2-3 verschiedene Spielzeuge</strong> reichen völlig aus. Zu viel Spielzeug lenkt ab und macht das Baden unübersichtlich. Tausche lieber regelmäßig durch, um die Neugier deines Babys aufrechtzuerhalten. Ein Badetier + ein Badebuch sind ein perfekter Start.'
  },
  {
    question: 'Sind elektrische Badespielzeuge sicher für Babys?',
    answer: 'Ja, wenn sie <strong>IPX7-wasserdicht</strong> und für die Altersgruppe zugelassen sind. Wiederaufladbare Spielzeuge (wie der PHNIXGAM Wal) haben versiegelte Ladeanschlüsse. Achte darauf, dass das Spielzeug nur im ausgeschalteten Zustand geladen wird und nie mit offenem Ladeanschluss ins Wasser kommt.'
  },
  {
    question: 'Kann ich Stoff-Badespielzeug in der Waschmaschine waschen?',
    answer: 'Die meisten Stoff-Badetiere (wie von Fehn) sind bei <strong>40°C waschbar</strong>. Wichtig: Nach dem Baden immer gut ausdrücken und vollständig trocknen lassen. Nicht im geschlossenen Behälter aufbewahren, sonst bildet sich Schimmel. Am besten in einem Netz mit Saugnäpfen in der Dusche aufhängen.'
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Badespielzeug Baby: Die 8 besten im Test 2026 – schimmelfrei & PVC-frei"
  description="Badespielzeug Baby Test 2026: Schimmelfreie Spritztiere, Badebücher & Wal-Sprinkler im Vergleich. PVC-frei, BPA-frei. Ab 8€ – ehrlich empfohlen."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <Breadcrumb items={[
      { label: 'Produkte', href: '/produkte/' },
      { label: 'Badespielzeug' }
    ]} />

    <!-- Intro -->
    <header class="mb-10">
      <span class="inline-block px-3 py-1 text-xs font-heading font-semibold bg-primary/10 text-primary-dark rounded-full mb-4">Produktvergleich</span>
      <h1 class="font-heading text-3xl md:text-4xl font-extrabold leading-tight mb-5">Badespielzeug Baby: Die 8 besten im Test 2026</h1>
      <p class="text-text-light text-lg leading-relaxed mb-4">
        Badespielzeug macht das Baden zum Erlebnis &ndash; und <strong>fördert gleichzeitig die Entwicklung</strong> deines Babys. Greifen, spritzen, stapeln, staunen: In der Badewanne trainiert dein Kind Feinmotorik, Ursache-Wirkung-Verständnis und sensorische Wahrnehmung. Von <strong>schimmelfreien Spritztieren</strong> über <strong>magische Badebücher</strong> bis zum <strong>leuchtenden Wal-Sprinkler</strong>: Hier unsere 8 ehrlichen Empfehlungen.
      </p>
      <p class="text-sm text-text-light italic">
        <em>Zuletzt aktualisiert: März 2026</em>
      </p>
    </header>

    <!-- Safety Badges -->
    <div class="mb-10 bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
      <h2 class="font-heading font-bold text-lg mb-4">&#128737; Sicherheits-Checkliste für Badespielzeug</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="flex flex-col items-center gap-2 p-3 text-center">
          <span class="text-2xl">&#9989;</span>
          <span class="text-sm font-heading font-semibold">PVC-frei</span>
          <p class="text-xs text-text-light">Schadstofffreies Silikon & ABS</p>
        </div>
        <div class="flex flex-col items-center gap-2 p-3 text-center">
          <span class="text-2xl">&#129440;</span>
          <span class="text-sm font-heading font-semibold">Schimmelfrei</span>
          <p class="text-xs text-text-light">Aufklappbar zum Reinigen</p>
        </div>
        <div class="flex flex-col items-center gap-2 p-3 text-center">
          <span class="text-2xl">&#128118;</span>
          <span class="text-sm font-heading font-semibold">BPA-frei</span>
          <p class="text-xs text-text-light">Sicher zum Nuckeln</p>
        </div>
        <div class="flex flex-col items-center gap-2 p-3 text-center">
          <span class="text-2xl">&#128065;</span>
          <span class="text-sm font-heading font-semibold">CE-geprüft</span>
          <p class="text-xs text-text-light">EU-Spielzeugrichtlinie</p>
        </div>
      </div>
    </div>

    <!-- Bestseller Top 3 Hero -->
    <div class="mb-10 bg-gradient-to-br from-accent/10 to-primary/5 rounded-2xl p-6 md:p-8 border-2 border-accent/30 shadow-sm">
      <p class="text-sm font-heading font-bold text-accent-dark mb-2">&#127942; Unsere Top 3 Empfehlungen 2026</p>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href={`https://www.amazon.de/dp/B0D7HGQRCG?tag=${AMAZON_TAG}`} target="_blank" rel="noopener noreferrer nofollow sponsored" class="block bg-white rounded-xl p-4 text-center border border-accent/20 hover:shadow-md transition-shadow">
          <span class="inline-block px-2 py-0.5 text-xs font-heading font-bold bg-accent text-text rounded-full mb-2">&#127942; Ab Geburt</span>
          <p class="font-heading font-bold text-sm">Fehn Otter &bdquo;Theo&ldquo;</p>
          <p class="text-xs text-text-light mt-1">&#11088; 4,7/5 (Amazon)</p>
          <p class="text-sm font-heading font-semibold text-primary-dark mt-1">ca. 11 €</p>
        </a>
        <a href={`https://www.amazon.de/dp/B0D9YBSSZQ?tag=${AMAZON_TAG}`} target="_blank" rel="noopener noreferrer nofollow sponsored" class="block bg-white rounded-xl p-4 text-center border border-accent/20 hover:shadow-md transition-shadow">
          <span class="inline-block px-2 py-0.5 text-xs font-heading font-bold bg-green-100 text-green-800 rounded-full mb-2">Schimmelfrei</span>
          <p class="font-heading font-bold text-sm">reer Spritztiere</p>
          <p class="text-xs text-text-light mt-1">&#11088; 4,6/5 &ndash; Aufklappbar</p>
          <p class="text-sm font-heading font-semibold text-primary-dark mt-1">ca. 6 €</p>
        </a>
        <a href={`https://www.amazon.de/dp/B09D8BTCT5?tag=${AMAZON_TAG}`} target="_blank" rel="noopener noreferrer nofollow sponsored" class="block bg-white rounded-xl p-4 text-center border border-accent/20 hover:shadow-md transition-shadow">
          <span class="inline-block px-2 py-0.5 text-xs font-heading font-bold bg-primary/10 text-primary-dark rounded-full mb-2">Farbwechsel</span>
          <p class="font-heading font-bold text-sm">reer Magisches Badebuch</p>
          <p class="text-xs text-text-light mt-1">&#11088; 4,6/5 &ndash; PVC-frei</p>
          <p class="text-sm font-heading font-semibold text-primary-dark mt-1">ca. 6 €</p>
        </a>
      </div>
    </div>

    <!-- Quick Navigation -->
    <nav class="mb-12 bg-white rounded-2xl p-6 border border-primary/10 shadow-sm">
      <h2 class="font-heading font-bold text-lg mb-4">&#128203; Auf dieser Seite</h2>
      <div class="grid sm:grid-cols-2 gap-2 text-sm">
        <a href="#badetiere" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Badetiere & Spritztiere (4 Produkte)
        </a>
        <a href="#badebuecher" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Badebücher & Sensorik (2 Produkte)
        </a>
        <a href="#wasserspielzeug" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Wasserspielzeug & Action (2 Produkte)
        </a>
        <a href="#pflege" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Pflege, Hygiene & Schimmel-Tipps
        </a>
        <a href="#alter" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Altersübersicht: Welches Spielzeug wann?
        </a>
        <a href="#faq" class="flex items-center gap-2 text-text-light hover:text-primary-dark transition-colors py-1">
          <span class="text-primary">&#10148;</span> Häufige Fragen (FAQ)
        </a>
      </div>
    </nav>

    <MamaTipp text="Badespielzeug lohnt sich erst ab ca. 6 Monaten, wenn dein Baby sicher sitzen kann und gezielt greifen will. Vorher genießt es einfach das warme Wasser &ndash; das ist Reiz genug. Starte mit einem weichen Badetier und einem Badebuch &ndash; mehr braucht es für den Anfang nicht." />

    <!-- Sicherheitshinweis -->
    <WichtigHinweis text="Lass dein Baby NIEMALS unbeaufsichtigt in der Badewanne &ndash; auch nicht mit Badespielzeug. Achte darauf, dass keine Kleinteile abbrechen können (Erstickungsgefahr). Prüfe Badespielzeug regelmäßig auf Risse, Schimmel und lose Teile." />

    <!-- ==================== -->
    <!-- 1. BADETIERE & SPRITZTIERE -->
    <!-- ==================== -->
    <section id="badetiere" class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">&#129414;</span>
        <h2 class="font-heading text-2xl font-extrabold">Badetiere & Spritztiere</h2>
      </div>
      <p class="text-text-light leading-relaxed mb-6">
        Der Klassiker unter dem Badespielzeug! Moderne Badetiere bestehen aus <strong>schadstofffreiem Silikon</strong> und lassen sich zum Reinigen öffnen &ndash; so hat Schimmel keine Chance. Ob süße Enten, kuschelige Otter oder weiche Schildkröten: Hier findest du unsere 4 Favoriten.
      </p>

      <!-- 1. reer MyHappyBath Toys -->
      <h3 class="font-heading font-bold text-xl mt-8 mb-3">1. reer MyHappyBath Toys Ente & Pinguin</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Die <strong>reer MyHappyBath Toys</strong> sind die clevere Antwort auf das größte Problem bei Badespielzeug: Schimmel! Das Set aus Ente und Pinguin lässt sich <strong>komplett auseinandernehmen</strong>, gründlich reinigen und hygienisch trocknen. Doppelte Spritzfunktion aus Schnabel oder Boden &ndash; Babys lieben es!
      </p>
      <AmazonProductBox
        name="reer MyHappyBath Toys Badetiere Ente & Pinguin"
        affiliateLink={`https://www.amazon.de/dp/B0D9YBSSZQ?tag=${AMAZON_TAG}`}
        features={[
          '2 Spritztiere im Set &ndash; Ente und Pinguin mit doppelter Spritzfunktion',
          'Auseinandernehmbar &ndash; kein Schimmel dank gründlicher Reinigung',
          'Hochwertiges Silikon &ndash; frei von Phthalaten, BPA und PVC',
          'Fördert motorische Entwicklung und Hand-Auge-Koordination',
          'Ab 6 Monaten geeignet'
        ]}
        rating="4,6/5"
        price="ca. 6 €"
        badge="Schimmelfrei"
        image="/images/products/reer-badetiere-ente-pinguin.jpg"
      />

      <!-- 2. BelleStyle Silikon Badetiere -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">2. BelleStyle Silikon Badetiere 4er-Set</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Das <strong>BelleStyle 4er-Set</strong> bietet gleich vier süße Silikonfreunde: Elefant, Koala, Pinguin und Dinosaurier. Jedes Tier lässt sich <strong>zweiteilig aufklappen</strong> &ndash; so kannst du es nach dem Baden komplett reinigen und trocknen lassen. Die perforierten Löcher erzeugen tolle Wassereffekte beim Drücken.
      </p>
      <AmazonProductBox
        name="BelleStyle Silikon Badetiere 4er-Set"
        affiliateLink={`https://www.amazon.de/dp/B0CSFKRMK4?tag=${AMAZON_TAG}`}
        features={[
          '4 Silikontiere: Elefant, Koala, Pinguin und Dinosaurier',
          'Zweiteilig aufklappbar &ndash; schimmelfrei durch einfache Reinigung',
          'Lebensmittelechtes Silikon, BPA-frei und ungiftig',
          'Perforierte Löcher für tolle Wasserspritz-Effekte',
          'Vielseitig: für Badewanne, Pool und Strand'
        ]}
        rating="4,3/5"
        price="ca. 10 €"
        badge="4er-Set"
        image="/images/products/bellestyle-silikon-badetiere.jpg"
      />

      <!-- 3. Fehn Badetier Otter -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">3. Fehn Badetier Otter &bdquo;Theo&ldquo;</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Der <strong>Fehn Otter &bdquo;Theo&ldquo;</strong> ist kein gewöhnliches Plastiktier, sondern ein <strong>kuschelweicher Stoff-Otter</strong>, der dank eingearbeitetem Schwimmball auf dem Wasser treibt. Mit seinen liebevollen Details aus Plüsch, Strick und Musselin lädt er zum Greifen und Kuscheln ein &ndash; im Wasser und danach. Deutsche Markenqualität von Fehn.
      </p>
      <AmazonProductBox
        name="Fehn Badetier Otter &bdquo;Theo&ldquo; 17 cm"
        affiliateLink={`https://www.amazon.de/dp/B0D7HGQRCG?tag=${AMAZON_TAG}`}
        features={[
          'Schwimmt auf der Wasseroberfläche dank eingearbeitetem Schwimmball',
          'Kuschelweiche Materialien: Plüsch, Strick und Musselin',
          'Fördert spielerisch Greifen, Fühlen und sensorische Wahrnehmung',
          'Waschbar bei 40°C &ndash; pflegeleicht und hygienisch',
          'Ab 0+ Monaten &ndash; auch schon für Neugeborene'
        ]}
        rating="4,7/5"
        price="ca. 11 €"
        badge="Empfehlung"
        image="/images/products/fehn-badetier-otter.jpg"
      />

      <!-- 4. Fehn Bade-Schwamm Schildkröte -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">4. Fehn Bade-Schwamm Schildkröte</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Die <strong>Fehn Bade-Schwamm Schildkröte</strong> kombiniert Spielzeug und Waschtuch in einem: Außen kuscheliger Frottee-Stoff, innen ein <strong>weicher Schwamm</strong> zum sanften Waschen der Babyhaut. Ideal für Babys, die beim Waschen etwas zum Festhalten und Spielen brauchen. Aus der beliebten &bdquo;Meereskinder&ldquo;-Kollektion.
      </p>
      <AmazonProductBox
        name="Fehn Bade-Schwamm Schildkröte &bdquo;Meereskinder&ldquo;"
        affiliateLink={`https://www.amazon.de/dp/B09F3MSBM6?tag=${AMAZON_TAG}`}
        features={[
          '2-in-1: Kuscheltier und Badeschwamm in einem',
          'Weicher Frottee-Stoff (78% Baumwolle, 22% Polyester)',
          'Eingearbeiteter Schwamm &ndash; sanft zu empfindlicher Babyhaut',
          'Liebevolle Details &ndash; Meereskinder-Kollektion von Fehn',
          'Waschbar bei 40°C &ndash; ab 0+ Monaten'
        ]}
        rating="4,7/5"
        price="ca. 9 €"
        image="/images/products/fehn-badeschwamm-schildkroete.jpg"
      />

      <MamaTipp text="Mein Favorit für den Start: Der Fehn Otter. Er schwimmt, ist kuschelig weich und kann schon ab Geburt verwendet werden. Für schimmelfreie Spritztiere empfehle ich die reer MyHappyBath Toys &ndash; die kann man zum Reinigen komplett auseinandernehmen!" />
    </section>

    <!-- ==================== -->
    <!-- 2. BADEBÜCHER & SENSORIK -->
    <!-- ==================== -->
    <section id="badebuecher" class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">&#128214;</span>
        <h2 class="font-heading text-2xl font-extrabold">Badebücher & Sensorik</h2>
      </div>
      <p class="text-text-light leading-relaxed mb-6">
        Badebücher verbinden <strong>Vorlesen mit Badespaß</strong> &ndash; und fördern gleichzeitig die visuelle Wahrnehmung. Sensorisches Spielzeug wie Saugnapf-Spinner trainiert die Feinmotorik. Beide Kategorien sind besonders für <strong>neugierige kleine Entdecker</strong> ab 6 Monaten geeignet.
      </p>

      <!-- 5. reer MyHappyBath Book -->
      <h3 class="font-heading font-bold text-xl mt-8 mb-3">5. reer MyHappyBath Book &ndash; Magisches Badebuch</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Das <strong>reer MyHappyBath Book</strong> ist echte Magie fürs Baby-Bad: Die Unterwasser-Motive <strong>ändern im Wasser ihre Farbe</strong> &ndash; weiße Tiere werden plötzlich bunt! Dazu eine Quietschfunktion auf der letzten Seite. Das PVC-freie Material schwimmt auf dem Wasser und hat weiche, abgerundete Kanten. Ein faszinierendes Erlebnis für kleine Entdecker.
      </p>
      <AmazonProductBox
        name="reer MyHappyBath Book &ndash; Magisches Badebuch mit Farbwechsel"
        affiliateLink={`https://www.amazon.de/dp/B09D8BTCT5?tag=${AMAZON_TAG}`}
        features={[
          'Magischer Farbwechsel-Effekt &ndash; weiße Tiere werden im Wasser bunt',
          '6 Seiten mit farbenfrohen Unterwasser-Illustrationen',
          'Integrierte Quietschfunktion für zusätzlichen Badespaß',
          'PVC-frei, weiche Kanten &ndash; sicher für Babyhände',
          'Schwimmt auf dem Wasser (15 x 15 cm) &ndash; ab 6 Monaten'
        ]}
        rating="4,6/5"
        price="ca. 6 €"
        badge="Empfehlung"
        image="/images/products/reer-badebuch-farbwechsel.jpg"
      />

      <!-- 6. Vanmor Saugnapf Spinner -->
      <h3 class="font-heading font-bold text-xl mt-10 mb-3">6. Vanmor Saugnapf-Spinner 4er-Set</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Die <strong>Vanmor Saugnapf-Spinner</strong> sind kleine Kreisel in süßen Tierformen (Biene, Schnecke, Schmetterling, Marienkäfer), die an der Badewanne, den Fliesen oder dem Hochstuhl haften. Einmal anstupsen, drehen sie sich faszinierend lange &ndash; das trainiert die <strong>Hand-Auge-Koordination</strong> und hält dein Baby minutenlang beschäftigt.
      </p>
      <AmazonProductBox
        name="Vanmor Saugnapf-Spinner Spielzeug 4er-Set"
        affiliateLink={`https://www.amazon.de/dp/B092S24B41?tag=${AMAZON_TAG}`}
        features={[
          '4 süße Tierformen: Biene, Schnecke, Schmetterling und Marienkäfer',
          'BPA-freies ABS und lebensmittelechtes Silikon',
          'Starke Saugnäpfe &ndash; haften an Badewanne, Fliesen und Hochstuhl',
          'Rostfreies Nylon-Lager &ndash; dreht sich lange und gleichmäßig',
          'Fördert Hand-Auge-Koordination und Feinmotorik &ndash; ab 1 Jahr'
        ]}
        rating="4,6/5"
        price="ca. 18 €"
        badge="Lernspielzeug"
        image="/images/products/vanmor-saugnapf-spinner.jpg"
      />
    </section>

    <!-- ==================== -->
    <!-- 3. WASSERSPIELZEUG & ACTION -->
    <!-- ==================== -->
    <section id="wasserspielzeug" class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">&#127754;</span>
        <h2 class="font-heading text-2xl font-extrabold">Wasserspielzeug & Action</h2>
      </div>
      <p class="text-text-light leading-relaxed mb-6">
