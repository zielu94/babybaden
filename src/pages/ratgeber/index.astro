---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featuredPost = sortedPosts.find(p => p.data.featured) || sortedPosts[0];
const otherPosts = sortedPosts.filter(p => p.id !== featuredPost.id);

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Ratgeber rund ums Baby-Baden',
  description: 'Alle Ratgeber-Artikel rund ums Baby-Baden: Anleitungen, Tipps, Sicherheitshinweise und mehr.',
  url: new URL('/ratgeber/', Astro.site).href,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: sortedPosts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(`/ratgeber/${post.id}/`, Astro.site).href,
      name: post.data.title,
    })),
  },
};
---

<BaseLayout
  title="Ratgeber rund ums Baby-Baden"
  description="Alle Ratgeber-Artikel rund ums Baby-Baden: Anleitungen, Tipps, Sicherheitshinweise und mehr."
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)} />
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12 md:py-16">
    <div class="text-center mb-12">
      <h1 class="font-heading text-3xl md:text-4xl font-extrabold">Ratgeber</h1>
      <p class="mt-4 text-text-light max-w-2xl mx-auto text-lg leading-relaxed">
        Alles was du über das Baden deines Babys wissen musst &ndash; von der Vorbereitung bis zur Pflege danach.
      </p>
    </div>

    <!-- Featured Article -->
    {featuredPost && (
      <div class="mb-12">
        <a href={`/ratgeber/${featuredPost.id}/`} class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-primary/10">
          <div class="grid md:grid-cols-2 gap-0">
            <div class="aspect-[16/10] md:aspect-auto bg-primary/10 overflow-hidden">
              {featuredPost.data.image ? (
                <img
                  src={featuredPost.data.image}
                  alt={featuredPost.data.imageAlt || ''}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  width="640"
                  height="400"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-primary/30 min-h-[200px]">
                  <svg class="w-20 h-20" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
                  </svg>
                </div>
              )}
            </div>
            <div class="p-6 md:p-8 lg:p-10 flex flex-col justify-center">
              <span class="inline-block px-3 py-1 text-xs font-heading font-semibold bg-accent/15 text-accent-dark rounded-full mb-4 w-fit">Empfohlen</span>
              <h2 class="font-heading text-xl md:text-2xl font-extrabold leading-snug group-hover:text-primary-dark transition-colors">
                {featuredPost.data.title}
              </h2>
              <p class="mt-3 text-text-light leading-relaxed">{featuredPost.data.description}</p>
              <span class="inline-flex items-center gap-1 mt-5 text-sm font-heading font-semibold text-primary-dark group-hover:gap-2 transition-all">
                Weiterlesen
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    )}

    <!-- All Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {otherPosts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          image={post.data.image}
          imageAlt={post.data.imageAlt}
          category={post.data.category}
          pubDate={post.data.pubDate}
        />
      ))}
    </div>
  </section>
</BaseLayout>
